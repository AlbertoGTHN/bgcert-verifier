# ============================================================
# ICCBPO Certificate QR Code Checker - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ----- APPLICATION -----
APP_NAME="ICCBPO Certificate Checker"
APP_ENV=development
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ----- DATABASE -----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=iccbpo_cert_checker
DB_USER=iccbpo
DB_PASSWORD=iccbpo_secure_pass_2024
DATABASE_URL=postgresql+asyncpg://iccbpo:iccbpo_secure_pass_2024@postgres:5432/iccbpo_cert_checker
DATABASE_URL_SYNC=postgresql://iccbpo:iccbpo_secure_pass_2024@postgres:5432/iccbpo_cert_checker

# ----- REDIS / CELERY -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass_2024
REDIS_URL=redis://:redis_secure_pass_2024@redis:6379/0
CELERY_BROKER_URL=redis://:redis_secure_pass_2024@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secure_pass_2024@redis:6379/1

# ----- JWT AUTH -----
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- FILE STORAGE -----
UPLOAD_DIR=/app/uploads
SCREENSHOT_DIR=/app/screenshots
REPORTS_DIR=/app/reports
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf
FILE_RETENTION_DAYS=90

# ----- ENCRYPTION -----
ENCRYPTION_KEY=your-fernet-encryption-key-32-bytes-base64-encoded

# ----- PLAYWRIGHT / HEADLESS BROWSER -----
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
SCREENSHOT_TIMEOUT_MS=10000

# ----- OCR -----
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGES=eng+spa+por+fra
OCR_DPI=300

# ----- VERIFICATION -----
REQUEST_TIMEOUT_SECONDS=30
MAX_REDIRECTS=5
VERIFY_SSL=true

# ----- EMAIL NOTIFICATIONS -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM=noreply@iccbpo.com
NOTIFICATION_ENABLED=false

# ----- AWS S3 (optional, leave blank for local storage) -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ----- AZURE BLOB (optional) -----
AZURE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=

# ----- MFA -----
MFA_ISSUER=ICCBPO CertChecker
MFA_ENABLED=false

# ----- RATE LIMITING -----
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ----- ADMIN DEFAULT (first-run only) -----
ADMIN_EMAIL=admin@iccbpo.com
ADMIN_PASSWORD=Admin@ICCBPO2024!
ADMIN_NAME=System Admin
